{
  "doc_type": "pipeline",
  "version": "3.0",
  "json_schema": "http://api.dataplatform.ibm.com/schemas/common-pipeline/pipeline-flow/pipeline-flow-v3-schema.json",
  "id": "elyra-ppe-full-lifecycle",
  "primary_pipeline": "primary",
  "pipelines": [
    {
      "id": "primary",
      "nodes": [
        {
          "id": "annotate-node",
          "type": "execution_node",
          "op": "execute-notebook-node",
          "app_data": {
            "component_parameters": {
              "filename": "01-annotate.ipynb",
              "runtime_image": "registry.redhat.io/rhoai/odh-pipeline-runtime-datascience-cpu-py312-rhel9@sha256:b772307d7e6409246a26b6fd762b374b14f969f95c91633e29815ce8523b6c3f",
              "dependencies": [],
              "include_subdirectories": false,
              "outputs": [],
              "env_vars": [
                {"env_var": "VLM_ENDPOINT",   "value": ""},
                {"env_var": "RAW_PREFIX",     "value": "workshop-data"},
                {"env_var": "DATASET_PREFIX", "value": "workshop-dataset"}
              ],
              "kubernetes_secrets": [
                {"env_var": "AWS_ACCESS_KEY_ID",     "name": "aws-connection-storage", "key": "AWS_ACCESS_KEY_ID"},
                {"env_var": "AWS_SECRET_ACCESS_KEY", "name": "aws-connection-storage", "key": "AWS_SECRET_ACCESS_KEY"},
                {"env_var": "AWS_S3_ENDPOINT",       "name": "aws-connection-storage", "key": "AWS_S3_ENDPOINT"},
                {"env_var": "AWS_DEFAULT_REGION",    "name": "aws-connection-storage", "key": "AWS_DEFAULT_REGION"},
                {"env_var": "AWS_S3_BUCKET",         "name": "aws-connection-storage", "key": "AWS_S3_BUCKET"},
                {"env_var": "VLLM_API_TOKEN",        "name": "vlm-credentials",        "key": "token", "optional": true}
              ]
            },
            "ui_data": {
              "label": "Annotate (VLM)",
              "image": "/static/elyra/notebook.svg",
              "x_pos": 120,
              "y_pos": 200,
              "description": "Call Qwen2.5-VL on raw images and emit YOLO-format labels."
            }
          },
          "inputs":  [{"id": "inPort"}],
          "outputs": [{"id": "outPort"}]
        },
        {
          "id": "train-node",
          "type": "execution_node",
          "op": "execute-notebook-node",
          "app_data": {
            "component_parameters": {
              "filename": "02-train.ipynb",
              "runtime_image": "registry.redhat.io/rhoai/odh-pipeline-runtime-datascience-cpu-py312-rhel9@sha256:b772307d7e6409246a26b6fd762b374b14f969f95c91633e29815ce8523b6c3f",
              "dependencies": [],
              "include_subdirectories": false,
              "outputs": ["model_uri.txt"],
              "env_vars": [
                {"env_var": "DATASET_PREFIX", "value": "workshop-dataset"},
                {"env_var": "MODEL_PREFIX",   "value": "models/ppe-yolov8n-vlm"},
                {"env_var": "MODEL_VERSION",  "value": "v1"},
                {"env_var": "EPOCHS",         "value": "20"},
                {"env_var": "IMG_SIZE",       "value": "640"},
                {"env_var": "BATCH",          "value": "16"}
              ],
              "kubernetes_secrets": [
                {"env_var": "AWS_ACCESS_KEY_ID",     "name": "aws-connection-storage", "key": "AWS_ACCESS_KEY_ID"},
                {"env_var": "AWS_SECRET_ACCESS_KEY", "name": "aws-connection-storage", "key": "AWS_SECRET_ACCESS_KEY"},
                {"env_var": "AWS_S3_ENDPOINT",       "name": "aws-connection-storage", "key": "AWS_S3_ENDPOINT"},
                {"env_var": "AWS_DEFAULT_REGION",    "name": "aws-connection-storage", "key": "AWS_DEFAULT_REGION"},
                {"env_var": "AWS_S3_BUCKET",         "name": "aws-connection-storage", "key": "AWS_S3_BUCKET"}
              ],
              "cpu": 2,
              "memory": 8
            },
            "ui_data": {
              "label": "Train YOLOv8n",
              "image": "/static/elyra/notebook.svg",
              "x_pos": 380,
              "y_pos": 200,
              "description": "Fine-tune yolov8n.pt on the VLM-annotated set; upload best.pt."
            }
          },
          "inputs":  [{"id": "inPort", "links": [{"node_id_ref": "annotate-node", "port_id_ref": "outPort"}]}],
          "outputs": [{"id": "outPort"}]
        },
        {
          "id": "deploy-node",
          "type": "execution_node",
          "op": "execute-notebook-node",
          "app_data": {
            "component_parameters": {
              "filename": "03-register-deploy.ipynb",
              "runtime_image": "registry.redhat.io/rhoai/odh-pipeline-runtime-datascience-cpu-py312-rhel9@sha256:b772307d7e6409246a26b6fd762b374b14f969f95c91633e29815ce8523b6c3f",
              "dependencies": [],
              "include_subdirectories": false,
              "outputs": ["endpoint.txt"],
              "env_vars": [
                {"env_var": "MODEL_PREFIX",         "value": "models/ppe-yolov8n-vlm"},
                {"env_var": "MODEL_VERSION",        "value": "v1"},
                {"env_var": "MODEL_NAME",           "value": "ppe-yolov8n-vlm"},
                {"env_var": "KUBERNETES_NAMESPACE", "value": "ppe-detection-cv"},
                {"env_var": "SERVING_RUNTIME",      "value": "ultralytics-yolo-runtime"},
                {"env_var": "SERVICE_ACCOUNT",      "value": "aws-connection-storage"}
              ],
              "kubernetes_secrets": [
                {"env_var": "AWS_S3_BUCKET",         "name": "aws-connection-storage", "key": "AWS_S3_BUCKET"},
                {"env_var": "MODEL_REGISTRY_URL",   "name": "model-registry-access",  "key": "url"},
                {"env_var": "MODEL_REGISTRY_PORT",  "name": "model-registry-access",  "key": "port",  "optional": true},
                {"env_var": "MODEL_REGISTRY_TOKEN", "name": "model-registry-access",  "key": "token"}
              ]
            },
            "ui_data": {
              "label": "Register + Deploy",
              "image": "/static/elyra/notebook.svg",
              "x_pos": 640,
              "y_pos": 200,
              "description": "Register in RHOAI Model Registry and deploy a KServe InferenceService."
            }
          },
          "inputs":  [{"id": "inPort", "links": [{"node_id_ref": "train-node", "port_id_ref": "outPort"}]}],
          "outputs": [{"id": "outPort"}]
        }
      ],
      "app_data": {
        "ui_data": {"comments": []},
        "version": 8,
        "runtime_type": "KUBEFLOW_PIPELINES",
        "properties": {
          "name": "full-lifecycle",
          "runtime": "Pipelines",
          "description": "Annotate (VLM) -> Train (YOLOv8n) -> Register + Deploy (Model Registry + KServe). Production-parallel of notebooks 02->05.",
          "pipeline_defaults": {
            "kubernetes_pod_labels": [],
            "kubernetes_shared_mem_size": {},
            "mounted_volumes": [],
            "kubernetes_pod_annotations": [],
            "kubernetes_tolerations": [],
            "kubernetes_secrets": [],
            "env_vars": [],
            "runtime_image": "registry.redhat.io/rhoai/odh-pipeline-runtime-datascience-cpu-py312-rhel9@sha256:b772307d7e6409246a26b6fd762b374b14f969f95c91633e29815ce8523b6c3f"
          }
        }
      },
      "runtime_ref": ""
    }
  ],
  "schemas": []
}
